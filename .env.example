# ─── Supabase ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── LLM (open-source via Ollama Cloud, OpenAI-compatible; needs tool calling) ─
LLM_BASE_URL=https://ollama.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-oss:120b
LLM_MAX_TOKENS=4096

# ─── App ─────────────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000

# ─── Apify (LinkedIn scraping + Reddit/X/LinkedIn-top-content research) ───────
APIFY_TOKEN=

# ─── Exa (web/blog research search — exa.ai) ─────────────────────────────────
EXA_API_KEY=

# ─── Cron ────────────────────────────────────────────────────────────────────
# Secret shared with Vercel Cron (sent as `Authorization: Bearer <secret>`).
# Protects /api/cron/*. Generate a long random string.
CRON_SECRET=
